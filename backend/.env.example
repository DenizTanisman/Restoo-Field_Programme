# Veritabanı — Dev ve Prod için PostgreSQL (asyncpg async driver)
DATABASE_URL=postgresql+asyncpg://opencard:opencard@localhost:5432/opencard
# Eski SQLite örneği (artık kullanılmıyor):
# DATABASE_URL=sqlite+aiosqlite:///./opencard_dev.db

# JWT
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — hangi frontend origin'lerine izin veriliyor
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5181","http://localhost:3000"]

# Depolama: local = disk (MEDIA_ROOT). Prod'da S3.
S3_BUCKET=local-bucket
S3_ACCESS_KEY=local
S3_SECRET_KEY=local
S3_REGION=us-east-1
CDN_BASE_URL=http://localhost:8003/media
STORAGE_PROVIDER=local

# Admin bootstrap — scripts/seed_admin.py ile bu bilgilerle ilk admin yaratılır
ADMIN_DEFAULT_EMAIL=admin@opencard.com
ADMIN_DEFAULT_PASSWORD=opencard123
ADMIN_DEFAULT_NAME=OpenCard Admin

# Yüklenen görseller (case study before/after vs.) bu klasöre kaydedilir
MEDIA_ROOT=./media
MEDIA_URL_PREFIX=/media
PUBLIC_BASE_URL=http://localhost:8003
